{
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/mark-abandoned",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/process-contact-limits",
      "schedule": "5-59/15 * * * *"
    }
  ]
}