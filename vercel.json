{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/cron/mark-abandoned",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/cron/process-contact-limits",
      "schedule": "5-59/15 * * * *"
    }
  ]
}